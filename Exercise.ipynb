   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "dates = pd.to_datetime(\"27th of July, 2020\")\n",
    "i = dates + pd.to_timedelta(np.arange(5),unit='D')\n",
    "d = [50,53,25,70,60]\n",
    "time_series = pd.Series(data=d,index=i)\n",
    "print(time_series)"
   ]
  }
